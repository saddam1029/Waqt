<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Waqt" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
    </style>

    <style name="Theme.Waqt"
        parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="SettingsSectionTitle">
        <item name="android:layout_marginTop">@dimen/_8sdp</item>
        <item name="android:layout_marginBottom">@dimen/_8sdp</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textColor">@color/section_title</item>
        <item name="android:textSize">@dimen/_11ssp</item>
    </style>

    <style name="SettingsCardStyle">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">@dimen/_12sdp</item>
        <item name="cardElevation">@dimen/_2sdp</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:layout_marginBottom">@dimen/_12sdp</item>
    </style>

    <style name="SettingsDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_1sdp</item>
        <item name="android:layout_marginStart">@dimen/_12sdp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <style name="PrayerAlarmItemText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/_14ssp</item>
    </style>
</resources>